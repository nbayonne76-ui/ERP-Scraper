# ── AI Scorer ─────────────────────────────────────────────────────────────────
# Claude Haiku (primary scorer) — get at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Search & Scraping APIs ────────────────────────────────────────────────────
# Tavily — AI-native search, 1000 free searches/month — tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Brave Search — fastest latency, independent index — api.search.brave.com
BRAVE_API_KEY=your_brave_api_key_here

# Firecrawl — JS-rendered portal scraping — firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Companies House — CIO/CFO appointment signals — developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key_here

# ── App Config ────────────────────────────────────────────────────────────────
PORT=8002
SCAN_INTERVAL_HOURS=6
